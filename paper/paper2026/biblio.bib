  author = {Pattle, Kate and Francesco, James Di and Hatchell, Jenny and Kirk, Helen and Sadavoy, Sarah and {Ward-Thompson}, Derek and Johnstone, Doug and Nittala, Sammohith and Kerr, Ronan and Keown, Jared and Butner, Harold and Coud{\'e}, Simon and Currie, Malcolm and Friesen, Rachel and Jenness, Tim and Knee, Lewis and White, Glenn},
