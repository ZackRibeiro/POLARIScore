@article{takemuraCARMANROOrionSurvey2023,
  title = {{{CARMA-NRO Orion Survey}}: Unbiased Survey of Dense Cores and Core Mass Functions in {{Orion A}}},
  shorttitle = {{{CARMA-NRO Orion Survey}}},
  author = {Takemura, Hideaki and Nakamura, Fumitaka and Arce, H{\'e}ctor G. and Schneider, Nicola and {Ossenkopf-Okada}, Volker and Kong, Shuo and Ishii, Shun and Dobashi, Kazuhito and Shimoikura, Tomomi and Sanhueza, Patricio and Tsukagoshi, Takashi and Padoan, Paolo and Klessen, Ralf S. and Goldsmith, Paul F. and Burkhart, Blakesley and {S{\'a}nchez-Monge}, Dariusz C. Lis {\'A}lvaro and Shimajiri, Yoshito and Kawabe, Ryohei},
  year = 2023,
  month = feb,
  journal = {The Astrophysical Journal Supplement Series},
  volume = {264},
  number = {2},
  eprint = {2211.10215},
  primaryclass = {astro-ph},
  pages = {35},
  issn = {0067-0049, 1538-4365},
  doi = {10.3847/1538-4365/aca4d4},
  urldate = {2025-10-21},
  abstract = {The mass distribution of dense cores is a potential key to understand the process of star formation. Applying dendrogram analysis to the CARMA-NRO Orion C\$\textasciicircum\textbraceleft 18\textbraceright\$O (\$J\$=1--0) data, we identify 2342 dense cores, about 22 \textbackslash\% of which have virial ratios smaller than 2, and can be classified as gravitationally bound cores. The derived core mass function (CMF) for bound starless cores which are not associate with protostars has a slope similar to Salpeter's initial mass function (IMF) for the mass range above 1 \$M\_\textbackslash odot\$, with a peak at \$\textbackslash sim\$ 0.1 \$M\_\textbackslash odot\$. We divide the cloud into four parts based on the declination, OMC-1/2/3, OMC-4/5, L1641N/V380 Ori, and L1641C, and derive the CMFs in these regions. We find that starless cores with masses greater than 10 \$M\_\textbackslash odot\$ exist only in OMC-1/2/3, whereas the CMFs in OMC-4/5, L1641N, and L1641C are truncated at around 5--10 \$M\_\textbackslash odot\$. From the number ratio of bound starless cores and Class II objects in each subregion, the lifetime of bound starless cores is estimated to be 5--30 free-fall times, consistent with previous studies for other regions. In addition, we discuss core growth by mass accretion from the surrounding cloud material to explain the coincidence of peak masses between IMFs and CMFs. The mass accretion rate required for doubling the core mass within a core lifetime is larger than that of Bondi-Hoyle accretion by a factor of order 2. This implies that more dynamical accretion processes are required to grow cores.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Solar and Stellar Astrophysics},
  file = {/home/zack/Zotero/storage/PJ9JPQWB/Takemura et al. - 2023 - CARMA-NRO Orion Survey unbiased survey of dense cores and core mass functions in Orion A.pdf;/home/zack/Zotero/storage/DBTVVBCZ/2211.html}
}

