@article{ksollDeeplearningApproach3D2024,
  title = {A Deep-Learning Approach to the {{3D}} Reconstruction of Dust Density and Temperature in Star-Forming Regions},
  author = {Ksoll, Victor F. and Reissl, Stefan and Klessen, Ralf S. and Stephens, Ian W. and Smith, Rowan J. and Soler, Juan D. and Traficante, Alessio and Testi, Leonardo and Hennebelle, Patrick and Molinari, Sergio},
  year = 2024,
  month = mar,
