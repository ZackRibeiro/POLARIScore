  volume = {635},
  pages = {A34},
  issn = {0004-6361, 1432-0746},
  doi = {10.1051/0004-6361/201834753},
  urldate = {2025-04-28},
  abstract = {We present a detailed study of the Orion B molecular cloud complex (               d               \textasciitilde{} 400 pc), which was imaged with the PACS and SPIRE photometric cameras at wavelengths from 70 to 500               {$\mu$}               m as part of the               Herschel               Gould Belt survey (HGBS). We release new high-resolution maps of column density and dust temperature for the whole complex, derived in the same consistent manner as for other HGBS regions. In the filamentary subregions NGC 2023 and 2024, NGC 2068 and 2071, and L1622, a total of 1768 starless dense cores were identified based on               Herschel               data, 490--804 (\textasciitilde 28-45\%) of which are self-gravitating prestellar cores that will likely form stars in the future. A total of 76 protostellar dense cores were also found. The typical lifetime of the prestellar cores was estimated to be               t               pre               OrionB               = 1.7               -0.6               +0.8               Myr. The prestellar core mass function (CMF) derived for the whole sample of prestellar cores peaks at \textasciitilde 0.5               M               {$\odot$}               (in d               N               /dlog               M               format) and is consistent with a power-law with logarithmic slope -1.27 \textpm{} 0.24 at the high-mass end, compared to the Salpeter slope of - 1.35. In the Orion B region, we confirm the existence of a transition in prestellar core formation efficiency (CFE) around a fiducial value               A               V               bg               \,\textasciitilde\,7 mag in background visual extinction, which is similar to the trend observed with               Herschel               in other regions, such as the Aquila cloud. This is not a sharp threshold, however, but a smooth transition between a regime with very low prestellar CFE at               A               V               bg               \,{$<$}\,5 and a regime with higher, roughly constant CFE at               A               V               bg               \,{$\greaterequivlnt$}\,10. The total mass in the form of prestellar cores represents only a modest fraction (\textasciitilde 20\%) of the dense molecular cloud gas above               A               V               bg               \,{$\greaterequivlnt$}\,7 mag. About 60--80\% of the prestellar cores are closely associated with filaments, and this fraction increases up to {$>$}90\% when a more complete sample of filamentary structures is considered. Interestingly, the median separation observed between nearest core neighbors corresponds to the typical inner filament width of \textasciitilde 0.1 pc, which is commonly observed in nearby molecular clouds, including Orion B. Analysis of the CMF observed as a function of background cloud column density shows that the most massive prestellar cores are spatially segregated in the highest column density areas, and suggests that both higher- and lower-mass prestellar cores may form in denser filaments.},
  copyright = {http://creativecommons.org/licenses/by/4.0},
  file = {/home/zack/Zotero/storage/7SE4NV4G/Könyves et al. - 2020 - Properties of the dense core population in Orion B as seen by the Herschel Gould Belt survey.pdf}
}

