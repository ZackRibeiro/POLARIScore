@article{konyvesPropertiesDenseCore2020,
  title = {Properties of the Dense Core Population in {{Orion B}} as Seen by the {{{\emph{Herschel}}}} {{Gould Belt}} Survey},
  author = {K{\"o}nyves, V. and Andr{\'e}, {\relax Ph}. and Arzoumanian, D. and Schneider, N. and Men'shchikov, A. and Bontemps, S. and Ladjelate, B. and Didelon, P. and Pezzuto, S. and Benedettini, M. and Bracco, A. and Di Francesco, J. and Goodwin, S. and Rygl, K. L. J. and Shimajiri, Y. and Spinoglio, L. and {Ward-Thompson}, D. and White, G. J.},
  year = 2020,
