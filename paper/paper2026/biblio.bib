  pages = {342--356},
  issn = {0035-8711, 1365-2966},
  doi = {10.1093/mnras/stw301},
  urldate = {2025-06-13},
  abstract = {We present a catalogue of dense cores in a \$\textbackslash sim 4\textasciicircum\textbackslash circ\textbackslash times2\textasciicircum\textbackslash circ\$ field of the Taurus star-forming region, inclusive of the L1495 cloud, derived from Herschel SPIRE and PACS observations in the 70 \$\textbackslash mu\$m, 160 \$\textbackslash mu\$m, 250 \$\textbackslash mu\$m, 350 \$\textbackslash mu\$m, and 500 \$\textbackslash mu\$m continuum bands. Estimates of mean dust temperature and total mass are derived using modified blackbody fits to the spectral energy distributions. We detect 525 starless cores of which \$\textbackslash sim10\$-20\% are gravitationally bound and therefore presumably prestellar. Our census of unbound objects is \$\textbackslash sim85\$\% complete for \$M{$>$}0.015\textbackslash,M\_\textbackslash odot\$ in low density regions (\$A\_V\textbackslash stackrel\textbraceleft{$<$}\textbraceright\textbraceleft\_\textbackslash sim\textbraceright 5\$ mag), while the bound (prestellar) subset is \$\textbackslash sim85\$\% complete for \$M{$>$}0.1\textbackslash,M\_\textbackslash odot\$ overall. The prestellar core mass function (CMF) is consistent with lognormal form, resembling the stellar system initial mass function, as has been reported previously. All of the inferred prestellar cores lie on filamentary structures whose column densities exceed the expected threshold for filamentary collapse, in agreement with previous reports. Unlike the prestellar CMF, the unbound starless CMF is not lognormal, but instead is consistent with a power-law form below \$0.3\textbackslash,M\_\textbackslash odot\$ and shows no evidence for a low-mass turnover. It resembles previously reported mass distributions for CO clumps at low masses (\$M\textbackslash stackrel\textbraceleft{$<$}\textbraceright\textbraceleft\_\textbackslash sim\textbraceright 0.3\textbackslash,M\_\textbackslash odot\$). The volume density PDF, however, is accurately lognormal except at high densities. It is consistent with the effects of self-gravity on magnetized supersonic turbulence. The only significant deviation from lognormality is a high-density tail which can be attributed unambiguously to prestellar cores.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Solar and Stellar Astrophysics},
  file = {/home/zack/Zotero/storage/W6TANPFY/Marsh et al. - 2016 - A census of dense cores in the Taurus L1495 cloud from the Herschel Gould Belt Survey.pdf;/home/zack/Zotero/storage/N2QTDYHU/1602.html}
}

