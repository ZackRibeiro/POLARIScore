@article{fuenteGasPhaseElemental2019,
  title = {Gas Phase {{Elemental}} Abundances in {{Molecular cloudS}} ({{GEMS}}): {{I}}. {{The}} Prototypical Dark Cloud {{TMC}} 1},
  shorttitle = {Gas Phase {{Elemental}} Abundances in {{Molecular cloudS}} ({{GEMS}})},
  author = {Fuente, A. and Navarro, D. G. and Caselli, P. and Gerin, M. and Kramer, C. and Roueff, E. and {Alonso-Albi}, T. and Bachiller, R. and Cazaux, S. and Commercon, B. and Friesen, R. and {Garc{\'i}a-Burillo}, S. and Giuliano, B. M. and Goicoechea, J. R. and Gratier, P. and Hacar, A. and {Jim{\'e}nez-Serra}, I. and Kirk, J. and Lattanzi, V. and Loison, J. C. and Malinen, J. and Marcelino, N. and {Mart{\'i}n-Dom{\'e}nech}, R. and {Mu{\~n}oz-Caro}, G. and Pineda, J. and Tafalla, M. and Tercero, B. and {Ward-Thompson}, D. and {Trevi{\~n}o-Morales}, S. P. and {Rivi{\'e}re-Marichalar}, P. and Roncero, O. and Vidal, T. and Ballester, M. Y.},
  year = 2019,
  month = apr,
  journal = {Astronomy \& Astrophysics},
  volume = {624},
  pages = {A105},
  issn = {0004-6361, 1432-0746},
  doi = {10.1051/0004-6361/201834654},
  urldate = {2025-05-15},
  abstract = {GEMS is an IRAM 30 m Large Program whose aim is determining the elemental depletions and the ionization fraction in a set of prototypical star-forming regions. This paper presents the first results from the prototypical dark cloud Taurus molecular cloud (TMC) 1. Extensive millimeter observations have been carried out with the IRAM 30 m telescope (3 and 2 mm) and the 40 m Yebes telescope (1.3 cm and 7 mm) to determine the fractional abundances of CO, HCO               +               , HCN, CS, SO, HCS               +               , and N               2               H               +               in three cuts which intersect the dense filament at the well-known positions TMC 1-CP, TMC 1-NH3, and TMC 1-C, covering a visual extinction range from               A               V               \textasciitilde{} 3 to \textasciitilde 20 mag. Two phases with differentiated chemistry can be distinguished: (i) the translucent envelope with molecular hydrogen densities of 1-5 \texttimes{} 10               3               cm               -3               ; and (ii) the dense phase, located at               A               V               {$>$} 10 mag, with molecular hydrogen densities {$>$}10               4               cm               -3               . Observations and modeling show that the gas phase abundances of C and O progressively decrease along the C               +               /C/CO transition zone (               A               V               \textasciitilde{} 3 mag) where C/H \textasciitilde{} 8 \texttimes{} 10               -5               and C/O \textasciitilde{} 0.8-1, until the beginning of the dense phase at               A               V               \textasciitilde{} 10 mag. This is consistent with the grain temperatures being below the CO evaporation temperature in this region. In the case of sulfur, a strong depletion should occur before the translucent phase where we estimate an               S               /               H               \textasciitilde{} (0.4-2.2) \texttimes{} 10               -6               , an abundance \textasciitilde 7--40 times lower than the solar value. A second strong depletion must be present during the formation of the thick icy mantles to achieve the values of S/H measured in the dense cold cores (               S               /               H               \textasciitilde{} 8 \texttimes{} 10               -8               ). Based on our chemical modeling, we constrain the value of               {$\zeta$}                                H                 2                              to \textasciitilde (0.5--1.8) \texttimes{} 10               -16               s               -1               in the translucent cloud.},
  copyright = {https://www.edpsciences.org/en/authors/copyright-and-licensing},
  file = {/home/zack/Zotero/storage/ZVSSS4ZT/Fuente et al. - 2019 - Gas phase Elemental abundances in Molecular cloudS (GEMS) I. The prototypical dark cloud TMC 1.pdf}
}

